# Drone Relay Docker Package
# Copy this file to .env before first launch.
# V3 rule: secrets live here, not in the admin page.

TZ=America/Chicago
PUBLIC_HOST=192.168.1.17

# Admin web UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
FLASK_SECRET_KEY=change-this-random-string

# API token for Home Assistant REST commands.
# Change this before exposing the admin page outside your LAN/Tailscale.
DRONE_API_TOKEN=change-this-api-token

# Default ports confirmed clear on linuxbox2
ADMIN_PORT=8589
RTMP_PORT=19350
HLS_PORT=8888
WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997

# Internal MediaMTX URLs used by the app container.
INPUT_RTMP=rtmp://mediamtx:1935/live/drone
PROGRAM_RTMP=rtmp://mediamtx:1935/live/program
MEDIAMTX_API=http://mediamtx:9997

# OpenWeather
# Get this from https://openweathermap.org/api
OPENWEATHER_API_KEY=

# YouTube output
# Keep the stream key private. Do not commit real values.
YOUTUBE_RTMP_URL=rtmps://a.rtmps.youtube.com/live2
YOUTUBE_STREAM_KEY=

# Twitch output, optional
# Keep the stream key private. Do not commit real values.
TWITCH_RTMP_URL=rtmp://live.twitch.tv/app
TWITCH_STREAM_KEY=

# Home Assistant, optional
HOME_ASSISTANT_URL=http://192.168.1.3:8123
HOME_ASSISTANT_TOKEN=
HA_PHONE_ENTITY=device_tracker.s24
HA_ZIP_OVERRIDE_ENTITY=input_text.drone_overlay_zip
HA_NOTIFY_SERVICE=notify.mobile_app_s24
