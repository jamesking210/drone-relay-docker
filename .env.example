# Drone Relay Docker Package
# Copy this file to .env before first launch.

TZ=America/Chicago

# Admin web UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
FLASK_SECRET_KEY=change-this-random-string

# API token for Home Assistant REST commands.
# Change this before exposing the admin page outside your LAN/Tailscale.
DRONE_API_TOKEN=change-this-api-token

# Default ports confirmed clear on linuxbox2
ADMIN_PORT=8589
RTMP_PORT=19350
HLS_PORT=8888
WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997

# Internal MediaMTX URLs used by the app container.
INPUT_RTMP=rtmp://mediamtx:1935/live/drone
PROGRAM_RTMP=rtmp://mediamtx:1935/live/program
MEDIAMTX_API=http://mediamtx:9997
