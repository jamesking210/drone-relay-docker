# Drone Relay Docker V9
# Secrets live here, not in the admin page.

TZ=America/Chicago
PUBLIC_HOST=192.168.1.17

# Admin web UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
FLASK_SECRET_KEY=change-this-random-string

# API token for Home Assistant REST commands
DRONE_API_TOKEN=change-this-api-token

# Ports confirmed clear on linuxbox2
ADMIN_PORT=8589
RTMP_PORT=19350
HLS_PORT=8888
WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997

# Internal MediaMTX URLs used by the app container
INPUT_RTMP=rtmp://mediamtx:1935/live/drone
PROGRAM_RTMP=rtmp://mediamtx:1935/live/program
PROGRAM_HLS_INTERNAL=http://mediamtx:8888/live/program/index.m3u8
RAW_HLS_INTERNAL=http://mediamtx:8888/live/drone/index.m3u8

# Encoder:
# auto = try Intel VAAPI first, fallback to CPU libx264 if FFmpeg dies immediately
# vaapi = Intel VAAPI only
# cpu = libx264 only
ENCODER_MODE=auto

# OpenWeather
OPENWEATHER_API_KEY=

# YouTube output
YOUTUBE_RTMP_URL=rtmps://a.rtmps.youtube.com/live2
YOUTUBE_STREAM_KEY=

# Twitch output
TWITCH_RTMP_URL=rtmp://live.twitch.tv/app
TWITCH_STREAM_KEY=

# Optional external audio sources
# Add these later when you know the stream URLs.
SCANNER_STREAM_URL=
AZURACAST_STREAM_URL=

# Home Assistant, optional
HOME_ASSISTANT_URL=http://192.168.1.3:8123
HOME_ASSISTANT_TOKEN=
HA_PHONE_ENTITY=device_tracker.s24
HA_ZIP_OVERRIDE_ENTITY=input_text.drone_overlay_zip
HA_NOTIFY_SERVICE=notify.mobile_app_s24
